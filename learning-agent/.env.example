# ===========================================
# Learning Agent 环境变量配置
# ===========================================

# ----- 基础配置（必需） -----

# OpenAI API密钥（必需）
OPENAI_API_KEY=your_api_key_here

# 主模型（强模型），用于 initial_analysis 节点
# 推荐：gpt-4o（性价比最优）、gpt-4（最稳定）、deepseek-chat（国产便宜）
OPENAI_MODEL=gpt-4

# API基础URL，可用于代理或切换到兼容API（如DeepSeek、Ollama）
OPENAI_API_BASE=https://api.openai.com/v1

# ----- 双模型配置（可选，默认关闭） -----

# 是否启用双模型策略
# false：所有节点统一使用 OPENAI_MODEL
# true：initial_analysis 用 OPENAI_MODEL，其余节点用 OPENAI_FAST_MODEL
DUAL_MODEL_ENABLED=false

# 快速模型，用于过滤/结构化/评估/笔记生成等简单任务
# 推荐：gpt-4o-mini（推荐）、gpt-3.5-turbo（最便宜）
# 支持本地 Ollama 模型，如 qwen2.5:7b、llama3.1:8b
OPENAI_FAST_MODEL=gpt-4o-mini

# 快速模型的 API 基础 URL（可选）
# 如果不设置，将使用 OPENAI_API_BASE
# 使用 Ollama 时设置为 http://localhost:11434/v1
# OPENAI_FAST_API_BASE=http://localhost:11434/v1

# 快速模型的 API 密钥（可选）
# 如果不设置，将使用 OPENAI_API_KEY
# 使用 Ollama 时设置为 ollama
# OPENAI_FAST_API_KEY=ollama
